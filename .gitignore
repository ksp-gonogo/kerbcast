# Rust
target/
**/*.rs.bk
# Cargo.lock IS committed — this crate ships as a binary (kerbcam-sidecar),
# so reproducible builds win over the lib-crate convention of ignoring it.

# .NET
bin/
obj/
*.user
*.suo
.vs/

# Build output
/dist/
/build/
# TypeScript packages — generated source IS committed (so consumers
# pulling from a tag don't need typeshare installed), but compiled
# output and pulled deps aren't.
client-sdk/typescript/dist/
client-sdk/react/dist/
node_modules/
# QEMU emulation coredumps from failed cross-builds
**/qemu_*_*.core
# Side-by-side Linux cross-build target dir (used when CARGO_TARGET_DIR
# points at a separate tree to avoid arch-mixing with native target/)
sidecar/target-linux/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/
# Browser-automation scratch output (Playwright MCP console/page dumps)
.playwright-mcp/

# Local scratch worktrees and Deck-deploy backups (binaries, scratch notes)
.worktrees/

# Local reference docs (cloned source repos, design notes, etc.)
local_docs/

# Serena project index (local tooling, not shipped)
.serena/

# docs/ ships only the two user-facing guides; everything else there is
# local working material (agent plans, reviews, backlogs).
docs/*
!docs/INSTALL.md
!docs/TROUBLESHOOTING.md
!docs/screenshots/

# Packaged binaries (built by CI, not committed)
GameData/Kerbcam/Sidecar/*/kerbcam-sidecar
GameData/Kerbcam/Sidecar/*/kerbcam-sidecar.exe
GameData/Kerbcam/Plugins/*.dll
