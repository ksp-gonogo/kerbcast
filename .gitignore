# Rust
target/
**/*.rs.bk
# Cargo.lock IS committed — this crate ships as a binary (kerbcam-sidecar),
# so reproducible builds win over the lib-crate convention of ignoring it.

# .NET
bin/
obj/
*.user
*.suo
.vs/

# Build output
/dist/
/build/
# QEMU emulation coredumps from failed cross-builds
**/qemu_*_*.core
# Side-by-side Linux cross-build target dir (used when CARGO_TARGET_DIR
# points at a separate tree to avoid arch-mixing with native target/)
sidecar/target-linux/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# Packaged binaries (built by CI, not committed)
GameData/KerbCam/Sidecar/*/kerbcam-sidecar
GameData/KerbCam/Sidecar/*/kerbcam-sidecar.exe
GameData/KerbCam/Plugin/*.dll
