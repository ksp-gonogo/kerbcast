{
  "name": "@ksp-gonogo/kerbcast",
  "version": "1.7.0",
  "description": "TypeScript client for the kerbcast KSP camera-streaming sidecar. KerbcastClient wraps the WebRTC peer + control channel; wire-format types are typeshare-generated from the sidecar's Rust protocol module.",
  "license": "MIT",
  "author": "Jon Pepler",
  "homepage": "https://github.com/ksp-gonogo/kerbcast#readme",
  "bugs": {
    "url": "https://github.com/ksp-gonogo/kerbcast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksp-gonogo/kerbcast.git",
    "directory": "client-sdk/typescript"
  },
  "keywords": [
    "kerbcast",
    "ksp",
    "kerbal-space-program",
    "webrtc",
    "h264",
    "protocol",
    "typeshare"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "regen": "typeshare ../../sidecar/src --lang=typescript --output-file=src/__generated__/types.ts",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
