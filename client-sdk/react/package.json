{
  "name": "@ksp-gonogo/kerbcast-react",
  "version": "1.6.2",
  "description": "React components and hooks for kerbcast camera feeds.",
  "license": "MIT",
  "author": "Jon Pepler",
  "homepage": "https://github.com/ksp-gonogo/kerbcast#readme",
  "bugs": {
    "url": "https://github.com/ksp-gonogo/kerbcast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksp-gonogo/kerbcast.git",
    "directory": "client-sdk/react"
  },
  "keywords": [
    "kerbcast",
    "ksp",
    "kerbal-space-program",
    "webrtc",
    "react",
    "camera"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ksp-gonogo/kerbcast": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "styled-components": "^6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
